---
import BaseLayout from '../layouts/BaseLayout.astro';

export interface Props {
  title: string;
  date: string;
  category: string;
}

const { title, date, category } = Astro.props;
---

<BaseLayout title={title}>
  <article class="max-w-4xl mx-auto">
    <header class="mb-8">
      <span class="text-blue-600 text-sm font-semibold">{category}</span>
      <h1 class="text-4xl font-bold mt-2 mb-4">{title}</h1>
      <p class="text-gray-500">Published on {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </header>
    
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
      <p class="text-sm text-gray-700">
        <strong>⚠️ Affiliate Disclosure:</strong> This post may contain affiliate links. 
        We earn a commission if you make a purchase, at no extra cost to you.
      </p>
    </div>
    
    <div class="prose lg:prose-xl max-w-none">
      <slot />
    </div>
    
    <footer class="mt-12 pt-8 border-t">
      <h3 class="text-xl font-bold mb-2">About PetFoodLab</h3>
      <p class="text-gray-600">
        We independently review pet food and supplements. Our reviews are based on 
        ingredient analysis, customer feedback, and veterinary research.
      </p>
    </footer>
  </article>
</BaseLayout>
