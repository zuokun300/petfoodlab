---
export interface Props {
  isOpen: boolean;
}

const { isOpen } = Astro.props;
---

<!-- Mobile Navigation Overlay -->
<div 
  id="mobileNav" 
  class="fixed inset-0 z-50 bg-gray-900/50 backdrop-blur-sm opacity-0 invisible transition-all duration-300 md:hidden"
  aria-hidden="true"
>
  <!-- Navigation Panel -->
  <nav class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300">
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b border-gray-200">
      <div class="flex items-center gap-2">
        <span class="text-3xl">🐾</span>
        <span class="text-xl font-bold font-outfit">PetFoodLab</span>
      </div>
      <button 
        id="closeMobileNav"
        class="p-2 hover:bg-gray-100 rounded-lg transition-colors"
        aria-label="Close menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Menu Items -->
    <div class="p-4 space-y-2">
      <a href="/" class="block py-3 px-4 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-colors font-medium">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Home
        </div>
      </a>

      <a href="/blog" class="block py-3 px-4 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-colors font-medium">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
          All Reviews
        </div>
      </a>

      <!-- Categories -->
      <div class="pt-4 pb-2">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3 px-4">Categories</h3>
        <a href="/blog" class="block py-2.5 px-4 rounded-lg hover:bg-gray-50 transition-colors text-gray-700">
          <div class="flex items-center gap-3">
            <span class="text-xl">🐕</span>
            Dog Food
          </div>
        </a>
        <a href="/blog" class="block py-2.5 px-4 rounded-lg hover:bg-gray-50 transition-colors text-gray-700">
          <div class="flex items-center gap-3">
            <span class="text-xl">🐱</span>
            Cat Food
          </div>
        </a>
        <a href="/blog" class="block py-2.5 px-4 rounded-lg hover:bg-gray-50 transition-colors text-gray-700">
          <div class="flex items-center gap-3">
            <span class="text-xl">💊</span>
            Supplements
          </div>
        </a>
      </div>

      <a href="/about" class="block py-3 px-4 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-colors font-medium">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          About Us
        </div>
      </a>

      <a href="/contact" class="block py-3 px-4 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-colors font-medium">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Contact
        </div>
      </a>
    </div>

    <!-- Footer CTA -->
    <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-200 bg-gray-50">
      <a href="/blog" class="btn-primary w-full flex items-center justify-center gap-2">
        Browse Reviews
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </nav>
</div>

<script>
  const mobileNav = document.getElementById('mobileNav');
  const navPanel = mobileNav?.querySelector('nav');
  const closeBtn = document.getElementById('closeMobileNav');

  function openMobileNav() {
    mobileNav?.classList.remove('opacity-0', 'invisible');
    navPanel?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileNav() {
    mobileNav?.classList.add('opacity-0', 'invisible');
    navPanel?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  // Open button listeners
  document.querySelectorAll('[data-open-mobile-nav]').forEach(btn => {
    btn.addEventListener('click', openMobileNav);
  });

  // Close button
  closeBtn?.addEventListener('click', closeMobileNav);

  // Close on overlay click
  mobileNav?.addEventListener('click', (e) => {
    if (e.target === mobileNav) {
      closeMobileNav();
    }
  });

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMobileNav();
    }
  });
</script>
