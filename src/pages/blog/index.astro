---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');

// Sort by date descending
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Pet Food Reviews & Guides - PetFoodLab">
  <h1 class="text-4xl font-bold mb-8">All Reviews & Guides</h1>
  
  <div class="grid md:grid-cols-2 gap-6">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="block bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <span class="text-sm text-blue-600">{post.data.category}</span>
        <h2 class="text-2xl font-semibold mt-2">{post.data.title}</h2>
        <p class="text-gray-500 mt-2">{post.data.date}</p>
      </a>
    ))}
  </div>
</BaseLayout>
