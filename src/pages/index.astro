---
import BaseLayout from '../layouts/BaseLayout.astro';

const topReviews = [
  { title: 'Best Dog Food 2026', slug: 'best-dog-food-2026', rating: 4.9 },
  { title: 'Best Cat Food 2026', slug: 'best-cat-food-2026', rating: 4.8 },
  { title: 'Best Probiotics for Dogs', slug: 'best-probiotics-dogs', rating: 4.7 },
];
---

<BaseLayout title="PetFoodLab - Independent Pet Food Reviews">
  <!-- Hero Section -->
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold mb-4">
      🐾 Independent Pet Food Reviews
    </h1>
    <p class="text-xl text-gray-600 mb-8">
      We test and review pet food so you don't have to. Honest reviews, science-backed recommendations.
    </p>
    <a href="/blog" class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700">
      Browse Reviews
    </a>
  </section>

  <!-- Top Reviews -->
  <section class="py-12">
    <h2 class="text-3xl font-bold mb-8 text-center">Top Reviews</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {topReviews.map((review) => (
        <a href={`/blog/${review.slug}`} class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
          <div class="flex items-center mb-2">
            <span class="text-yellow-500">⭐</span>
            <span class="ml-2 font-semibold">{review.rating}</span>
          </div>
          <h3 class="text-xl font-semibold">{review.title}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="py-12">
    <h2 class="text-3xl font-bold mb-8 text-center">Browse by Category</h2>
    <div class="grid md:grid-cols-4 gap-4">
      <a href="/blog" class="bg-blue-50 p-6 rounded-lg text-center hover:bg-blue-100">
        🐕 Dog Food
      </a>
      <a href="/blog" class="bg-blue-50 p-6 rounded-lg text-center hover:bg-blue-100">
        🐱 Cat Food
      </a>
      <a href="/blog" class="bg-blue-50 p-6 rounded-lg text-center hover:bg-blue-100">
        💊 Supplements
      </a>
      <a href="/blog" class="bg-blue-50 p-6 rounded-lg text-center hover:bg-blue-100">
        🦴 Treats
      </a>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <section class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 mt-12">
    <h3 class="font-semibold mb-2">📋 Affiliate Disclosure</h3>
    <p class="text-gray-600 text-sm">
      PetFoodLab is reader-supported. When you buy through links on our site, we may earn an affiliate commission at no extra cost to you. 
      This helps us continue providing independent reviews.
    </p>
  </section>
</BaseLayout>
