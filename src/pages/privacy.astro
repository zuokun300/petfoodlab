---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy">
  <h1 class="text-4xl font-bold mb-8">Privacy Policy</h1>
  
  <div class="prose lg:prose-xl">
    <p class="text-gray-600">Last updated: March 2026</p>

    <h2>Information We Collect</h2>
    <p>
      We collect minimal information:
    </p>
    <ul>
      <li>Website analytics (via Google Analytics)</li>
      <li>Affiliate click tracking (to improve recommendations)</li>
    </ul>

    <h2>How We Use Information</h2>
    <p>
      We use this data to:
    </p>
    <ul>
      <li>Improve our content and recommendations</li>
      <li>Understand which reviews are most helpful</li>
    </ul>

    <h2>Third-Party Services</h2>
    <ul>
      <li>Google Analytics - analytics</li>
      <li>Amazon Associates - affiliate links</li>
      <li>Vercel - website hosting</li>
    </ul>

    <h2>Contact</h2>
    <p>
      Questions about privacy? Contact us at 
      <a href="mailto:privacy@petfoodlab.it.com" class="text-blue-600">privacy@petfoodlab.it.com</a>
    </p>
  </div>
</BaseLayout>
