---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About PetFoodLab - Our Mission">
  <!-- Header -->
  <section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">About PetFoodLab</h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">
        Helping pet owners make informed decisions through independent, science-backed reviews
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Mission -->
      <div class="mb-16">
        <div class="text-6xl mb-6">🎯</div>
        <h2 class="text-3xl font-bold mb-4">Our Mission</h2>
        <p class="text-xl text-gray-600 leading-relaxed mb-6">
          PetFoodLab was founded in 2026 by pet owners who were frustrated by the lack of honest, 
          science-backed pet food reviews. Too many sites are influenced by manufacturer partnerships 
          or affiliate commissions.
        </p>
        <p class="text-xl text-gray-600 leading-relaxed">
          We take a different approach: every review is based on ingredient analysis, nutritional science, 
          and real customer feedback.
        </p>
      </div>

      <!-- How We Review -->
      <div class="mb-16">
        <div class="text-6xl mb-6">🔬</div>
        <h2 class="text-3xl font-bold mb-6">Our Review Process</h2>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="card p-6">
            <div class="text-3xl mb-3">1️⃣</div>
            <h3 class="text-xl font-bold mb-2">Ingredient Analysis</h3>
            <p class="text-gray-600">We evaluate every ingredient for quality, safety, and nutritional value.</p>
          </div>

          <div class="card p-6">
            <div class="text-3xl mb-3">2️⃣</div>
            <h3 class="text-xl font-bold mb-2">Nutritional Completeness</h3>
            <p class="text-gray-600">We verify AAFCO compliance and nutritional adequacy for different life stages.</p>
          </div>

          <div class="card p-6">
            <div class="text-3xl mb-3">3️⃣</div>
            <h3 class="text-xl font-bold mb-2">Customer Feedback</h3>
            <p class="text-gray-600">We analyze thousands of verified reviews to understand real-world performance.</p>
          </div>

          <div class="card p-6">
            <div class="text-3xl mb-3">4️⃣</div>
            <h3 class="text-xl font-bold mb-2">Value Assessment</h3>
            <p class="text-gray-600">We calculate price per serving for fair comparisons across brands.</p>
          </div>
        </div>
      </div>

      <!-- Our Promise -->
      <div class="mb-16">
        <div class="text-6xl mb-6">✅</div>
        <h2 class="text-3xl font-bold mb-6">Our Promise</h2>
        
        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl">
            <span class="text-2xl">✓</span>
            <div>
              <h3 class="font-bold mb-1">Independent reviews</h3>
              <p class="text-gray-600">We buy products ourselves. No manufacturer influence.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl">
            <span class="text-2xl">✓</span>
            <div>
              <h3 class="font-bold mb-1">Transparent affiliate disclosure</h3>
              <p class="text-gray-600">We clearly disclose all affiliate relationships.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl">
            <span class="text-2xl">✓</span>
            <div>
              <h3 class="font-bold mb-1">Science-backed recommendations</h3>
              <p class="text-gray-600">Our reviews are based on nutritional science and veterinary research.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-8">
        <h2 class="text-3xl font-bold mb-4">Get in Touch</h2>
        <p class="text-gray-700 mb-6">
          Have questions, suggestions, or product review requests? We'd love to hear from you!
        </p>
        <a href="/contact" class="btn-primary inline-flex items-center gap-2">
          Contact Us
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
