---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact PetFoodLab">
  <h1 class="text-4xl font-bold mb-8">Contact Us</h1>
  
  <div class="prose lg:prose-xl">
    <p class="text-xl text-gray-600 mb-8">
      Have questions, suggestions, or product review requests? We'd love to hear from you!
    </p>

    <h2>Get in Touch</h2>
    <ul>
      <li><strong>Email:</strong> <a href="mailto:hello@petfoodlab.it.com" class="text-blue-600">hello@petfoodlab.it.com</a></li>
      <li><strong>Response Time:</strong> 24-48 hours</li>
    </ul>

    <h2>Product Review Requests</h2>
    <p>
      Want us to review a specific product? Send us:
    </p>
    <ul>
      <li>Product name and brand</li>
      <li>Where to buy it</li>
      <li>Why you think it's worth reviewing</li>
    </ul>

    <h2>Advertising & Partnerships</h2>
    <p>
      For advertising inquiries, contact 
      <a href="mailto:ads@petfoodlab.it.com" class="text-blue-600">ads@petfoodlab.it.com</a>
    </p>
    <p class="text-sm text-gray-500">
      Note: We maintain editorial independence. Advertising does not influence our reviews.
    </p>
  </div>
</BaseLayout>
